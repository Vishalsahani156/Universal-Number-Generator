# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=phone_generator

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_RATE_LIMIT_DB=1
REDIS_PROGRESS_DB=2

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# File storage (local dev: ./data/exports — Docker Compose overrides to /data/exports)
EXPORTS_DIR=./data/exports
FILE_RETENTION_HOURS=72
CHUNK_SIZE=50000

# Rate limiting (skipped when APP_ENV=development)
RATE_LIMIT_JOBS_PER_HOUR_IP=100
RATE_LIMIT_JOBS_PER_DAY_SESSION=500

# Job limits
MIN_QUANTITY=1
# MAX_QUANTITY=   # optional cap; leave unset for no maximum
XLSX_MAX_ROWS=1048576

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Download tokens
DOWNLOAD_TOKEN_TTL_SECONDS=900
